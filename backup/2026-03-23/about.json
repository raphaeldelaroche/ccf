                "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567803a-item-1773239179660-75p1nl6",
                "blockType": "blob",
                "data": {
                  "title": "Mirova Research Center",
                  "subtitle": "Research branch of sustainable asset manager Mirova, the Research Center brings expertise in climate analysis, transition finance, and responsible investment. It ensures the academic and financial credibility of the CCF methodology."
                },
                "innerBlocks": []
              }
            ],
