                "blockType": "blob",
                "data": {
                  "title": "Sweep",
                  "subtitle": "Leading platform for sustainability data management. Sweep supports large companies in collecting, analyzing, and communicating their climate data. Its technical infrastructure is at the heart of CCF integration into existing reporting systems.",
                  "align": "right"
                },
                "innerBlocks": []
              },
