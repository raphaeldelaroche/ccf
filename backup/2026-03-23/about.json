    {
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567801",
      "blockType": "blob",
      "data": {
        "eyebrow": "About",
        "title": "A new consortium for corporate climate action.",
        "subtitle": "The Climate Contribution Framework (CCF) was created to address a growing climate accountability gap: while companies increasingly disclose their emissions and transition plans, their overall contribution to global Net Zero remains fragmented, difficult to compare, and undervalued.",
        "showContent": "false",
        "figureType": "none",
        "appearance": "borderBottom",
        "responsive": {
          "base": {
            "layout": "stack",
            "align": "center",
            "size": "8xl",
            "paddingX": "container-xl",
            "paddingY": "9xl",
            "headerPaddingX": "container-sm"
          }
        }
      },
      "innerBlocks": []
    },
    {
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567803",
      "blockType": "blob",
      "data": {
        "eyebrow": "Origin of the framework",
        "title": "Co-initiated by Sweep and the Mirova Research Center.",
        "subtitle": "Together, these organizations combined climate science, financial research, and operational expertise to design a robust, transparent, and scalable methodology.",
        "showContent": "true",
        "contentType": "innerBlocks",
        "appearance": "borderBottom",
        "responsive": {
          "base": {
            "layout": "stack",
            "align": "center",
