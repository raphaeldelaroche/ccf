{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "preset.schema.json",
  "title": "BlockPreset",
  "description": "Un preset de bloc réutilisable dans BlobUI",
  "type": "object",
  "required": ["slug", "name", "blockType", "template"],
  "additionalProperties": false,
  "properties": {
    "slug": {
      "type": "string",
      "description": "Identifiant unique du preset",
      "pattern": "^[a-z0-9-]+$",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "description": "Nom du preset",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "Description du preset"
    },
    "tags": {
      "type": "array",
      "description": "Tags pour catégoriser le preset",
      "items": { "type": "string" }
    },
    "blockType": {
      "type": "string",
      "enum": ["BlobBlock", "BlobSection", "BlobIterator"],
      "description": "Type de bloc du preset"
    },
    "useCase": {
      "type": "string",
      "description": "Cas d'usage du preset"
    },
    "template": {
      "type": "object",
      "description": "Le bloc template (sans ID)",
      "required": ["blockType", "data", "innerBlocks"],
      "additionalProperties": false,
      "properties": {
        "blockType": {
          "type": "string",
          "enum": ["BlobBlock", "BlobSection", "BlobIterator"]
        },
        "data": {
          "type": "object",
          "additionalProperties": true
        },
        "innerBlocks": {
          "type": "array",
          "items": { "$ref": "./block.schema.json" }
        },
        "meta": {
          "type": "object",
          "properties": {
            "collapsed": { "type": "boolean" },
            "locked": { "type": "boolean" },
            "visible": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      }
    },
    "meta": {
      "type": "object",
      "description": "Métadonnées du preset",
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "author": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
