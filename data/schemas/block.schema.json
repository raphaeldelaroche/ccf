{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "block.schema.json",
  "title": "BlockNote Block",
  "description": "Un bloc au format natif BlockNote (compatible avec les custom blocks BlobUI)",
  "type": "object",
  "required": ["id", "type", "props", "content", "children"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifiant unique du bloc (UUID)"
    },
    "type": {
      "type": "string",
      "description": "Type de bloc. Natifs BlockNote : paragraph, heading, bulletListItem, numberedListItem, checkListItem, table, image, video, file, audio, codeBlock, quote, divider, pageBreak. Custom BlobUI : blob, blobSection, blobIterator."
    },
    "props": {
      "type": "object",
      "description": "Propriétés du bloc. Toujours présent, même vide.",
      "properties": {
        "backgroundColor": {
          "type": "string",
          "description": "Couleur de fond (\"default\" = pas de couleur)"
        },
        "textColor": {
          "type": "string",
          "description": "Couleur du texte (\"default\" = couleur du thème)"
        },
        "textAlignment": {
          "type": "string",
          "enum": ["left", "center", "right", "justify"],
          "description": "Alignement du texte"
        },
        "level": {
          "type": "number",
          "enum": [1, 2, 3],
          "description": "Niveau de heading (heading uniquement)"
        },
        "checked": {
          "type": "boolean",
          "description": "État coché (checkListItem uniquement)"
        },
        "language": {
          "type": "string",
          "description": "Langage de code (codeBlock uniquement)"
        },
        "url": {
          "type": "string",
          "description": "URL du média (image, video, file, audio)"
        },
        "caption": {
          "type": "string",
          "description": "Légende du média"
        },
        "previewWidth": {
          "type": "number",
          "description": "Largeur d'aperçu du média en pixels"
        },
        "showPreview": {
          "type": "boolean",
          "description": "Afficher l'aperçu du média"
        },
        "name": {
          "type": "string",
          "description": "Nom du fichier (file uniquement)"
        }
      },
      "additionalProperties": true
    },
    "content": {
      "description": "Contenu inline du bloc. Tableau de textes/liens pour les blocs texte, tableau de lignes pour table, tableau vide pour les blocs sans contenu inline (custom blocks, divider, etc.).",
      "oneOf": [
        {
          "type": "array",
          "description": "Contenu inline (textes et liens)",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "description": "Texte avec styles",
                "required": ["type", "text", "styles"],
                "additionalProperties": false,
                "properties": {
                  "type": { "type": "string", "enum": ["text"] },
                  "text": { "type": "string" },
                  "styles": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              },
              {
                "type": "object",
                "description": "Lien hypertexte",
                "required": ["type", "href", "content"],
                "additionalProperties": false,
                "properties": {
                  "type": { "type": "string", "enum": ["link"] },
                  "href": { "type": "string" },
                  "content": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["type", "text", "styles"],
                      "additionalProperties": false,
                      "properties": {
                        "type": { "type": "string", "enum": ["text"] },
                        "text": { "type": "string" },
                        "styles": { "type": "object", "additionalProperties": true }
                      }
                    }
                  }
                }
              },
              {
                "type": "object",
                "description": "Saut de ligne",
                "required": ["type"],
                "properties": {
                  "type": { "type": "string", "enum": ["hardBreak"] }
                }
              }
            ]
          }
        },
        {
          "type": "string",
          "description": "Contenu spécial (ex: \"none\" pour certains types custom)"
        }
      ]
    },
    "children": {
      "type": "array",
      "description": "Blocs enfants imbriqués (ex: items d'une liste imbriquée)",
      "items": { "$ref": "#" }
    }
  }
}

